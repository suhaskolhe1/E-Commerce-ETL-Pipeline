# AWS S3 Data Lake Configuration
S3_BUCKET_NAME=your-s3-bucket-name
AWS_REGION=us-east-1

# AWS Redshift Data Warehouse Configuration
REDSHIFT_HOST=your-redshift-cluster-url.redshift.amazonaws.com
REDSHIFT_PORT=5439
REDSHIFT_DATABASE=your-database-name
REDSHIFT_USER=your-database-user
REDSHIFT_PASSWORD=your-database-password
REDSHIFT_IAM_ROLE=arn:aws:iam::123456789012:role/your-redshift-role
